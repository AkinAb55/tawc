<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:name=".TawcApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Tawc"
        android:extractNativeLibs="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".compositor.CompositorActivity"
            android:exported="false"
            android:theme="@style/Theme.Tawc.Compositor"
            android:documentLaunchMode="intoExisting"
            android:taskAffinity=""
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="stateHidden|adjustResize" />

        <service
            android:name=".compositor.CompositorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="wayland_compositor" />
        </service>

        <activity
            android:name=".install.InstallActivity"
            android:exported="false"
            android:label="@string/title_install_distro" />

        <activity
            android:name=".install.DistroInfoActivity"
            android:exported="false"
            android:label="@string/title_distro_info" />

        <activity
            android:name=".install.InstallMethodInfoActivity"
            android:exported="false"
            android:label="@string/title_install_methods" />

        <activity
            android:name=".install.ManageBindsActivity"
            android:exported="false"
            android:label="@string/title_manage_binds" />

        <activity
            android:name=".install.DirectoryPickerActivity"
            android:exported="false"
            android:label="@string/title_directory_picker" />

        <activity
            android:name=".tasks.TaskManagerActivity"
            android:exported="false"
            android:label="@string/title_task_manager" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings" />

        <!-- Новая Activity для просмотра логов -->
        <activity
            android:name=".LogActivity"
            android:exported="false"
            android:label="TAWC Logs" />

        <activity
            android:name=".ops.LogScreenActivity"
            android:exported="true"
            android:label="@string/title_operation_log" />

        <receiver
            android:name=".ops.CancelOperationReceiver"
            android:exported="false" />

        <activity
            android:name=".terminal.TerminalActivity"
            android:exported="false"
            android:documentLaunchMode="intoExisting"
            android:taskAffinity=""
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".launcher.LaunchErrorActivity"
            android:exported="false"
            android:theme="@style/Theme.Tawc.DialogHost"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:excludeFromRecents="true" />

        <activity
            android:name=".launcher.LauncherActivity"
            android:exported="false"
            android:label="@string/title_launcher"
            android:theme="@style/Theme.Tawc.Launcher"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".launcher.DesktopFileEditorActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".launcher.ShortcutLaunchActivity"
            android:exported="false"
            android:theme="@style/Theme.Tawc.DialogHost"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:taskAffinity="" />

        <service
            android:name=".install.InstallationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
