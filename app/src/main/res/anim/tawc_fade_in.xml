<?xml version="1.0" encoding="utf-8"?>
<!--
  Linear 150ms fade for activity transitions. Paired with
  tawc_fade_out so the two alphas sum to ~1.0 throughout — a clean
  cross-fade with no "both invisible" dip and no late-stage snap.
  Stock android.R.anim.fade_in/_out are too long (500ms) and use
  accelerate/decelerate curves tuned for "view appearing/dismissing in
  isolation," not for screen-to-screen swaps.
-->
<alpha xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/linear_interpolator"
    android:fromAlpha="0.0"
    android:toAlpha="1.0"
    android:duration="150"/>
