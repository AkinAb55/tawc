<?xml version="1.0" encoding="utf-8"?>
<!-- HTTPS-only across the board. Both bootstrap fetches go over TLS:
     Arch x86_64 via geo.mirror.pkgbuild.com, ALARM aarch64 via
     fl.us.mirror.archlinuxarm.org / ca.us.mirror.archlinuxarm.org
     (regional ALARM mirrors with proper certs). See
     notes/installation.md "Bootstrap integrity" — plaintext is
     forbidden here on purpose; do not re-add carve-outs without
     replacing them with another integrity barrier. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
