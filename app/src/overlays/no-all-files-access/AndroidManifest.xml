<?xml version="1.0" encoding="utf-8"?>
<!-- Build-type manifest overlay selected by `-PtawcAllFilesAccess=false`
     (see app/build.gradle.kts): strips MANAGE_EXTERNAL_STORAGE from the
     merged manifest for distribution channels that can't carry it
     (Google Play review). The app detects the absence at runtime
     (AllFilesAccess.declared) and hides the external-binds UI. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:node="remove" />

</manifest>
