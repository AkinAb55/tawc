diff --git a/meson.build b/meson.build
index adb48cb..64303ba 100644
--- a/meson.build
+++ b/meson.build
@@ -78,6 +78,21 @@ elif host_machine.system() == 'linux'
   gfxstream_host_args += '-DGFXSTREAM_UNSTABLE_VULKAN_EXTERNAL_SYNC=1'
   gfxstream_host_args += '-DGFXSTREAM_UNSTABLE_VULKAN_BLOB_COLOR_BUFFER=1'
   gfxstream_host_args += '-DHAVE_MEMFD_CREATE=1'
+elif host_machine.system() == 'android'
+  thread_dep = dependency('threads')
+  gfxstream_host_args += '-DGFXSTREAM_UNSTABLE_VULKAN_EXTERNAL_SYNC=1'
+  gfxstream_host_args += '-DGFXSTREAM_UNSTABLE_VULKAN_BLOB_COLOR_BUFFER=1'
+  # NDK clang defines __ANDROID__ but not the bare `ANDROID` macro;
+  # several files (egl_global_info.cpp, egl_os_api_egl.cpp,
+  # vk_android_native_buffer_gfxstream.h, …) check `#if defined(ANDROID)`
+  # to pick the Android code path. Define it explicitly so they take
+  # the right branch.
+  gfxstream_host_args += '-DANDROID=1'
+  # NDK exposes memfd_create(3) only since API 30. We compile against
+  # API 28 to match the app's minSdk; SharedMemory_posix.cpp falls
+  # through to a __NR_memfd_create syscall when HAVE_MEMFD_CREATE is
+  # undefined, which works on every kernel that ships with Android 11+
+  # (the bridge backend's effective floor).
 else
   thread_dep = dependency('threads')
 endif
diff --git a/third_party/meson.build b/third_party/meson.build
index 9dcda01..cb899ad 100644
--- a/third_party/meson.build
+++ b/third_party/meson.build
@@ -23,3 +23,13 @@ inc_opengl_headers = include_directories('opengl/include')
 inc_common_opengl = include_directories('opengl/include')
 inc_drm_headers = include_directories('drm/include')
 
+# Android: gfxstream-internal headers under cutils/, vndk/, android/
+# that aren't shipped in the NDK (cutils/native_handle.h, etc.).
+# We bring them in as a header-only include path for android targets
+# only — they shouldn't shadow the NDK's own android/* headers.
+if host_machine.system() == 'android'
+  inc_third_party_android = include_directories('android/include')
+else
+  inc_third_party_android = include_directories()
+endif
