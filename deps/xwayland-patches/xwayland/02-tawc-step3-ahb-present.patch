diff --git a/hw/xwayland/xwayland-tawc-libnativewindow.c b/hw/xwayland/xwayland-tawc-libnativewindow.c
new file mode 100644
index 000000000..993feac9f
--- /dev/null
+++ b/hw/xwayland/xwayland-tawc-libnativewindow.c
@@ -0,0 +1,117 @@
+/*
+ * SPDX-License-Identifier: MIT
+ *
+ * libnativewindow.so dlopen wrapper. Bionic-only; we link against the
+ * NDK already, but going through dlopen keeps libnativewindow out of
+ * Xwayland's DT_NEEDED so a build that's never run on a real Android
+ * device (e.g. the unit-test harness) doesn't fail to load.
+ *
+ * AHardwareBuffer_getNativeHandle is "private" in NDK header parlance
+ * (declared in private/android/AHardwareBufferHelpers.h) but is in
+ * libnativewindow.so's exported map under LIBNATIVEWINDOW_PLATFORM —
+ * dlsym sees it. We need it because android_wlegl ships native_handle
+ * payload (numFds, numInts, fds, ints), not opaque AHB handles, so
+ * we have to crack the AHB to get the native_handle ABI back.
+ *
+ * See notes/xwayland.md.
+ */
+
+#ifdef HAVE_DIX_CONFIG_H
+#include <dix-config.h>
+#endif
+
+#include "xwayland-tawc-libnativewindow.h"
+
+#include <dlfcn.h>
+#include <pthread.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <string.h>
+
+#include "os.h"
+
+/* Function-pointer typedefs — match libnativewindow's NDK shape. */
+typedef void (*pfn_release_t)(struct AHardwareBuffer *);
+typedef const struct tawc_native_handle *
+             (*pfn_get_handle_t)(const struct AHardwareBuffer *);
+typedef int  (*pfn_from_handle_t)(const struct tawc_ahb_desc *,
+                                  const struct tawc_native_handle *,
+                                  int32_t method,
+                                  struct AHardwareBuffer **);
+
+/* From AOSP frameworks/native/libs/nativewindow/include/private/android/
+ * AHardwareBufferHelpers.h. METHOD_REGISTER means the AHB takes ownership
+ * of the handle's fds. */
+#define TAWC_AHB_METHOD_REGISTER 2
+
+static pfn_release_t     g_release;
+static pfn_get_handle_t  g_get_handle;
+static pfn_from_handle_t g_from_handle;
+static int               g_loaded;
+
+static pthread_once_t g_once = PTHREAD_ONCE_INIT;
+
+static void
+load_once(void)
+{
+    void *lib = dlopen("libnativewindow.so", RTLD_NOW | RTLD_GLOBAL);
+    if (!lib) {
+        ErrorF("xwl_tawc: dlopen(libnativewindow.so) failed: %s\n",
+               dlerror());
+        return;
+    }
+    g_release     = (pfn_release_t)    dlsym(lib, "AHardwareBuffer_release");
+    g_get_handle  = (pfn_get_handle_t) dlsym(lib, "AHardwareBuffer_getNativeHandle");
+    g_from_handle = (pfn_from_handle_t) dlsym(lib, "AHardwareBuffer_createFromHandle");
+
+    if (!g_release || !g_get_handle || !g_from_handle) {
+        ErrorF("xwl_tawc: dlsym AHardwareBuffer_* failed "
+               "(release=%p get_handle=%p from_handle=%p)\n",
+               (void *)g_release, (void *)g_get_handle, (void *)g_from_handle);
+        return;
+    }
+    g_loaded = 1;
+}
+
+int
+xwl_tawc_libnativewindow_load(void)
+{
+    pthread_once(&g_once, load_once);
+    return g_loaded;
+}
+
+void
+xwl_tawc_ahb_release(struct AHardwareBuffer *ahb)
+{
+    if (!ahb || !xwl_tawc_libnativewindow_load())
+        return;
+    g_release(ahb);
+}
+
+const struct tawc_native_handle *
+xwl_tawc_ahb_get_native_handle(struct AHardwareBuffer *ahb)
+{
+    if (!ahb || !xwl_tawc_libnativewindow_load())
+        return NULL;
+    return g_get_handle(ahb);
+}
+
+int
+xwl_tawc_ahb_create_from_handle(const struct tawc_ahb_desc *desc,
+                                const struct tawc_native_handle *handle,
+                                struct AHardwareBuffer **out)
+{
+    if (!xwl_tawc_libnativewindow_load() || !desc || !handle || !out)
+        return -1;
+    *out = NULL;
+    int rc = g_from_handle(desc, handle, TAWC_AHB_METHOD_REGISTER, out);
+    if (rc != 0 || !*out) {
+        ErrorF("xwl_tawc: AHardwareBuffer_createFromHandle failed rc=%d "
+               "(%ux%u fmt=%u stride=%u usage=0x%llx numFds=%d numInts=%d)\n",
+               rc, desc->width, desc->height, desc->format, desc->stride,
+               (unsigned long long)desc->usage,
+               handle->numFds, handle->numInts);
+        return rc != 0 ? rc : -1;
+    }
+    return 0;
+}
diff --git a/hw/xwayland/xwayland-tawc-libnativewindow.h b/hw/xwayland/xwayland-tawc-libnativewindow.h
new file mode 100644
index 000000000..763f23827
--- /dev/null
+++ b/hw/xwayland/xwayland-tawc-libnativewindow.h
@@ -0,0 +1,66 @@
+/*
+ * SPDX-License-Identifier: MIT
+ *
+ * Thin wrapper around libnativewindow.so — bionic NDK API for AHB
+ * allocation, plus the (exported-but-private) AHardwareBuffer_getNativeHandle
+ * symbol we need to ship a buffer over android_wlegl. See notes/xwayland.md.
+ */
+
+#ifndef XWAYLAND_TAWC_LIBNATIVEWINDOW_H
+#define XWAYLAND_TAWC_LIBNATIVEWINDOW_H
+
+#include <stdint.h>
+
+/* Opaque to callers; we don't pull in <android/hardware_buffer.h>
+ * because Xwayland's includes don't establish an Android NDK sysroot
+ * for every TU. Pointers only. */
+struct AHardwareBuffer;
+
+/* Mirror of cutils' native_handle_t. Stable ABI. */
+struct tawc_native_handle {
+    int version;   /* sizeof(native_handle_t) = 12 */
+    int numFds;
+    int numInts;
+    int data[];    /* numFds fds, then numInts ints */
+};
+
+/* AHardwareBuffer_Desc subset (matches the NDK layout). */
+struct tawc_ahb_desc {
+    uint32_t width;
+    uint32_t height;
+    uint32_t layers;
+    uint32_t format;
+    uint64_t usage;
+    uint32_t stride;
+    uint32_t rfu0;
+    uint64_t rfu1;
+};
+
+/* Format constants we actually use, mirrored so callers don't need
+ * <android/hardware_buffer.h>. */
+#define TAWC_AHB_FORMAT_R8G8B8A8_UNORM      1
+#define TAWC_AHB_FORMAT_R8G8B8X8_UNORM      2
+#define TAWC_AHB_FORMAT_B8G8R8A8_UNORM      5
+
+/* Resolve symbols from libnativewindow.so. Returns 1 on success, 0 on
+ * failure. Idempotent; safe to call repeatedly. */
+int xwl_tawc_libnativewindow_load(void);
+
+/* AHardwareBuffer_release. */
+void xwl_tawc_ahb_release(struct AHardwareBuffer *ahb);
+
+/* AHardwareBuffer_createFromHandle: rebuild an AHB from a wire-format
+ * native_handle (numFds, numInts, fds, ints). Mirrors what
+ * compositor/native/wlegl_import.c does on the compositor side. The
+ * AHB takes ownership of the fds in `handle->data[0..numFds]` on
+ * success; on failure the caller still owns them. Returns 0 on success. */
+int xwl_tawc_ahb_create_from_handle(const struct tawc_ahb_desc *desc,
+                                    const struct tawc_native_handle *handle,
+                                    struct AHardwareBuffer **out);
+
+/* Borrow the AHB's underlying native_handle_t. Lifetime bound to the
+ * AHB; do not free. The pointer becomes invalid after _release(). */
+const struct tawc_native_handle *
+xwl_tawc_ahb_get_native_handle(struct AHardwareBuffer *ahb);
+
+#endif /* XWAYLAND_TAWC_LIBNATIVEWINDOW_H */
diff --git a/hw/xwayland/xwayland-tawc.c b/hw/xwayland/xwayland-tawc.c
new file mode 100644
index 000000000..efb462eb0
--- /dev/null
+++ b/hw/xwayland/xwayland-tawc.c
@@ -0,0 +1,286 @@
+/*
+ * SPDX-License-Identifier: MIT
+ *
+ * TAWC AHB buffer transport for Xwayland.
+ *
+ * The protocol shape we send is identical to libhybris's wayland
+ * platform plugin (libhybris/hybris/platforms/wayland/
+ * wayland_window_common.cpp:59), which is what tawc's compositor
+ * accepts from Wayland clients via android_wlegl in v1 mode:
+ *
+ *   1. android_wlegl.create_handle(num_fds, ints[]) -> handle
+ *   2. handle.add_fd(fd) repeated num_fds times
+ *   3. android_wlegl.create_buffer(width, height, stride, format,
+ *                                  usage, handle) -> wl_buffer
+ *   4. handle.destroy()
+ *
+ * The compositor's wlegl_import.c then rebuilds an AHardwareBuffer
+ * from the (fds, ints) pair via AHardwareBuffer_createFromHandle.
+ *
+ * See notes/xwayland.md.
+ */
+
+#ifdef HAVE_DIX_CONFIG_H
+#include <dix-config.h>
+#endif
+
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <wayland-client.h>
+
+#include <X11/X.h>
+#include "os.h"
+#include "windowstr.h"
+
+#include "xwayland-screen.h"
+#include "xwayland-window.h"
+#include "xwayland-tawc.h"
+#include "xwayland-tawc-libnativewindow.h"
+
+#include "android_wlegl-client-protocol.h"
+
+void
+xwl_tawc_buffer_destroy(struct xwl_tawc_buffer *buf)
+{
+    if (!buf)
+        return;
+    if (buf->buffer)
+        wl_buffer_destroy(buf->buffer);
+    if (buf->ahb)
+        xwl_tawc_ahb_release(buf->ahb);
+    free(buf);
+}
+
+/* Build a wl_buffer from a tawc_native_handle using the v1
+ * create_handle / add_fd / create_buffer sequence. The compositor
+ * speaks v2 of the protocol but rejects get_server_buffer_handle
+ * (server-side allocation), so client-side allocation via these v1
+ * requests is the only path. */
+static struct wl_buffer *
+ship_native_handle(struct android_wlegl *wlegl,
+                   const struct tawc_native_handle *handle,
+                   int width, int height, int stride,
+                   int format, uint64_t usage)
+{
+    struct android_wlegl_handle *wlegl_handle;
+    struct wl_array ints;
+    struct wl_buffer *buffer;
+    int *ints_data;
+
+    wl_array_init(&ints);
+    ints_data = wl_array_add(&ints, handle->numInts * sizeof(int));
+    if (!ints_data) {
+        wl_array_release(&ints);
+        return NULL;
+    }
+    memcpy(ints_data,
+           handle->data + handle->numFds,
+           handle->numInts * sizeof(int));
+
+    wlegl_handle = android_wlegl_create_handle(wlegl, handle->numFds, &ints);
+    wl_array_release(&ints);
+    if (!wlegl_handle)
+        return NULL;
+
+    for (int i = 0; i < handle->numFds; i++)
+        android_wlegl_handle_add_fd(wlegl_handle, handle->data[i]);
+
+    /* usage is uint32_t on the wire — the AHB usage high bits are
+     * gralloc4-internal and the compositor's wlegl_import.c masks
+     * to (uint32_t) anyway. */
+    buffer = android_wlegl_create_buffer(wlegl, width, height, stride,
+                                         format, (uint32_t)usage,
+                                         wlegl_handle);
+    android_wlegl_handle_destroy(wlegl_handle);
+    return buffer;
+}
+
+struct wl_buffer *
+xwl_tawc_buffer_get_wl_buffer(struct xwl_screen *xwl_screen,
+                              struct xwl_tawc_buffer *buf)
+{
+    const struct tawc_native_handle *handle;
+
+    if (!buf || !buf->ahb)
+        return NULL;
+    if (buf->buffer)
+        return buf->buffer;
+    if (!xwl_screen->tawc_wlegl) {
+        ErrorF("xwl_tawc: compositor does not advertise android_wlegl\n");
+        return NULL;
+    }
+
+    handle = xwl_tawc_ahb_get_native_handle(buf->ahb);
+    if (!handle) {
+        ErrorF("xwl_tawc: AHardwareBuffer_getNativeHandle failed\n");
+        return NULL;
+    }
+
+    buf->buffer = ship_native_handle(xwl_screen->tawc_wlegl, handle,
+                                     buf->width, buf->height, buf->stride,
+                                     buf->format, buf->usage);
+    if (!buf->buffer) {
+        ErrorF("xwl_tawc: android_wlegl create_buffer failed\n");
+        return NULL;
+    }
+    return buf->buffer;
+}
+
+/* Step-3 stub: a real impl will look up the xwl_tawc_buffer stashed on
+ * the PixmapPtr by the TAWC-DRI handler and route through the standalone
+ * shipping helpers. For now it returns NULL — TAWC-DRI bypasses the
+ * pixmap router and attaches its wl_buffer directly to the X11 window's
+ * wl_surface, since we don't need to compose AHB-backed pixmaps with the
+ * X server's normal drawing flow yet. */
+struct wl_buffer *
+xwl_tawc_pixmap_get_wl_buffer(PixmapPtr pixmap)
+{
+    (void) pixmap;
+    return NULL;
+}
+
+/* Compositor signals it's done with one of our shipped wl_buffers.
+ * Free the corresponding xwl_tawc_buffer, which destroys the wl_buffer
+ * and releases the AHB (which in turn closes the dup'd fds). Without
+ * this, every present leaks an FD per fd-in-the-handle and the
+ * compositor process trips RLIMIT_NOFILE within seconds of any
+ * sustained-frame client (es2gears_x11, glmark2-es2, …). */
+static void
+buffer_release(void *data, struct wl_buffer *buffer)
+{
+    struct xwl_tawc_buffer *buf = data;
+    (void) buffer;
+    xwl_tawc_buffer_destroy(buf);
+}
+
+static const struct wl_buffer_listener buffer_release_listener = {
+    .release = buffer_release,
+};
+
+/* TAWC-DRI step 3: client-shipped native_handle → AHB → wl_buffer →
+ * direct attach + commit on the X11 window's wl_surface.
+ *
+ * This bypasses the X server's normal pixmap flow: rather than wrap the
+ * AHB as an X pixmap and let xwl_window_present_pixmap handle the
+ * compositor handoff, we attach to the wl_surface ourselves. That means
+ * server-side X11 drawing on the same window won't see this AHB
+ * (no XGetImage, no XCopyArea integration). Pure GL clients don't do
+ * those, which is the Phase 2 use case. Mixed-rendering would race the
+ * X server's normal SHM root pixmap attach over this one.
+ *
+ * Lifecycle: a fresh xwl_tawc_buffer + AHB + wl_buffer is allocated per
+ * present. Each wl_buffer carries `buffer_release_listener`, which
+ * destroys the trio when the compositor releases its reference. That
+ * keeps the live working set bounded by the compositor's queue depth
+ * (typically ≤3) regardless of how many frames the client renders.
+ */
+int
+xwl_tawc_present_native_handle(WindowPtr window,
+                               int *fds, int num_fds,
+                               const int32_t *ints, int num_ints,
+                               int width, int height, int stride,
+                               int format, uint64_t usage)
+{
+    struct xwl_screen *xwl_screen;
+    struct xwl_window *xwl_window;
+    struct tawc_native_handle *handle = NULL;
+    struct tawc_ahb_desc desc;
+    struct AHardwareBuffer *ahb = NULL;
+    struct xwl_tawc_buffer *buf = NULL;
+    struct wl_buffer *wlbuf;
+    size_t handle_sz;
+    int rc = BadAlloc;
+
+    if (!window || num_fds < 0 || num_ints < 0 || width <= 0 || height <= 0)
+        goto err_close_fds;
+
+    xwl_screen = xwl_screen_get(window->drawable.pScreen);
+    if (!xwl_screen->tawc_wlegl) {
+        ErrorF("xwl_tawc: TAWC-DRI Present without android_wlegl bound\n");
+        rc = BadMatch;
+        goto err_close_fds;
+    }
+
+    xwl_window = xwl_window_from_window(window);
+    if (!xwl_window || !xwl_window->surface) {
+        ErrorF("xwl_tawc: TAWC-DRI Present on unmapped/unsurfaced window 0x%lx\n",
+               (unsigned long)window->drawable.id);
+        rc = BadMatch;
+        goto err_close_fds;
+    }
+
+    /* Build a wire-format native_handle: header + numFds fds + numInts ints. */
+    handle_sz = sizeof(*handle) +
+                (size_t)(num_fds + num_ints) * sizeof(int);
+    handle = malloc(handle_sz);
+    if (!handle)
+        goto err_close_fds;
+    handle->version = (int)sizeof(*handle);
+    handle->numFds  = num_fds;
+    handle->numInts = num_ints;
+    for (int i = 0; i < num_fds;  i++) handle->data[i]           = fds[i];
+    for (int i = 0; i < num_ints; i++) handle->data[num_fds + i] = ints[i];
+
+    memset(&desc, 0, sizeof(desc));
+    desc.width  = (uint32_t)width;
+    desc.height = (uint32_t)height;
+    desc.layers = 1;
+    desc.format = (uint32_t)format;
+    desc.usage  = usage;
+    desc.stride = (uint32_t)stride;
+
+    /* AHB METHOD_REGISTER takes ownership of the entire handle struct
+     * AND its fds — same ABI as compositor/native/wlegl_import.c. Do
+     * NOT free(handle) on success: the underlying GraphicBuffer
+     * close+deletes the handle when the AHB is released, and a manual
+     * free trips Scudo's chunk-state check. */
+    if (xwl_tawc_ahb_create_from_handle(&desc, handle, &ahb) != 0) {
+        rc = BadValue;
+        goto err_free_handle;
+    }
+    handle = NULL;
+    /* Caller's fds are now owned by the AHB; don't close them. */
+    for (int i = 0; i < num_fds; i++) fds[i] = -1;
+
+    buf = calloc(1, sizeof(*buf));
+    if (!buf) {
+        xwl_tawc_ahb_release(ahb);
+        return BadAlloc;
+    }
+    buf->ahb    = ahb;
+    buf->width  = width;
+    buf->height = height;
+    buf->stride = stride;
+    buf->format = format;
+    buf->usage  = usage;
+
+    wlbuf = xwl_tawc_buffer_get_wl_buffer(xwl_screen, buf);
+    if (!wlbuf) {
+        xwl_tawc_buffer_destroy(buf);
+        return BadAlloc;
+    }
+
+    /* Tie buffer lifetime to the compositor's release event so we don't
+     * leak an FD per present. See `buffer_release_listener` block. */
+    wl_buffer_add_listener(wlbuf, &buffer_release_listener, buf);
+
+    /* Direct wl_surface attach — bypasses the X-side pixmap flow. See
+     * the comment above this function. */
+    wl_surface_attach(xwl_window->surface, wlbuf, 0, 0);
+    wl_surface_damage(xwl_window->surface, 0, 0, width, height);
+    wl_surface_commit(xwl_window->surface);
+
+    /* The compositor side logs `wlegl: create_buffer ...` and
+     * `wlegl: imported ANativeWindowBuffer as texture ...` per AHB
+     * import; logging here would be redundant noise (a 60 fps client
+     * would fire it once per frame). Keep silent on the success path. */
+    return Success;
+
+ err_free_handle:
+    free(handle);
+ err_close_fds:
+    for (int i = 0; i < num_fds; i++)
+        if (fds[i] >= 0) close(fds[i]);
+    return rc;
+}
diff --git a/hw/xwayland/xwayland-tawc.h b/hw/xwayland/xwayland-tawc.h
new file mode 100644
index 000000000..6342e5950
--- /dev/null
+++ b/hw/xwayland/xwayland-tawc.h
@@ -0,0 +1,73 @@
+/*
+ * SPDX-License-Identifier: MIT
+ *
+ * TAWC AHB buffer transport for Xwayland.
+ *
+ * Wraps an AHardwareBuffer as a wl_buffer via the android_wlegl
+ * protocol so the compositor can import it through its existing
+ * gralloc1 path (compositor/native/wlegl_import.c). The protocol is
+ * the same one libhybris's wayland-platform plugin uses
+ * (libhybris/hybris/platforms/wayland/wayland_window_common.cpp:59),
+ * which is what the compositor already accepts from ordinary Wayland
+ * clients.
+ *
+ * See notes/xwayland.md.
+ */
+
+#ifndef XWAYLAND_TAWC_H
+#define XWAYLAND_TAWC_H
+
+#include "scrnintstr.h"
+#include "pixmap.h"
+
+struct AHardwareBuffer;
+struct wl_buffer;
+struct xwl_screen;
+
+/* AHB-backed buffer + lazily-created wl_buffer. xwl_tawc_present_native_handle
+ * allocates one per TAWC-DRI present and ties its lifetime to the
+ * compositor's wl_buffer.release event. */
+struct xwl_tawc_buffer {
+    struct AHardwareBuffer *ahb;   /* Owned. */
+    struct wl_buffer *buffer;      /* Lazy; created on first
+                                    * xwl_tawc_buffer_get_wl_buffer. */
+    int width;
+    int height;
+    int stride;     /* In pixels, as reported by AHardwareBuffer_describe. */
+    int format;     /* Android pixel format (AHARDWAREBUFFER_FORMAT_*). */
+    uint64_t usage; /* AHB usage flags. */
+};
+
+/* Tear down: destroys the wl_buffer (if any), releases the AHB, frees
+ * the xwl_tawc_buffer struct. */
+void xwl_tawc_buffer_destroy(struct xwl_tawc_buffer *buf);
+
+/* Lazily ship the AHB to the compositor via android_wlegl and return
+ * the resulting wl_buffer. Returns NULL if the compositor doesn't
+ * advertise android_wlegl, or buffer creation fails. */
+struct wl_buffer *
+xwl_tawc_buffer_get_wl_buffer(struct xwl_screen *xwl_screen,
+                              struct xwl_tawc_buffer *buf);
+
+/* Stub: routes an AHB-backed PixmapPtr through the same shipping path.
+ * Returns NULL because TAWC-DRI bypasses the pixmap router and attaches
+ * its wl_buffer directly to the X11 window's wl_surface. */
+struct wl_buffer *xwl_tawc_pixmap_get_wl_buffer(PixmapPtr pixmap);
+
+/* TAWC-DRI entry point. Reconstructs an AHardwareBuffer from a
+ * client-shipped native_handle (numFds fds + numInts ints), wraps it
+ * as an xwl_tawc_buffer, attaches the resulting wl_buffer directly to
+ * the X11 window's wl_surface, and commits. Takes ownership of the
+ * fds in `fds[0..num_fds]` on success (closes them on failure too —
+ * AHardwareBuffer_createFromHandle's REGISTER mode owns them on success
+ * via the AHB; on failure we close ourselves).
+ *
+ * Returns 0 on success, X protocol error code (BadValue / BadMatch /
+ * BadAlloc) on failure. */
+int xwl_tawc_present_native_handle(WindowPtr window,
+                                   int *fds, int num_fds,
+                                   const int32_t *ints, int num_ints,
+                                   int width, int height, int stride,
+                                   int format, uint64_t usage);
+
+#endif /* XWAYLAND_TAWC_H */
