+ *
+ * TAWC AHB buffer transport for Xwayland — Phase 1 stub. Returns
+ * NULL; the existing GLAMOR/SHM split in xwayland-pixmap.c is
+ * unaffected. Phase 2 will fill this in with android_wlegl bind +
+ * libnativewindow AHB allocation. See notes/xwayland.md.
+ */
+
+#ifdef HAVE_DIX_CONFIG_H
+#include <dix-config.h>
+#endif
+
+#include "xwayland-tawc.h"
+
+struct wl_buffer *
+xwl_tawc_pixmap_get_wl_buffer(PixmapPtr pixmap)
+{
+    (void) pixmap;
+    return NULL;
+}
