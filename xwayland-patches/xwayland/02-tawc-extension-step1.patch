diff --git a/Xext/tawc-dri.c b/Xext/tawc-dri.c
new file mode 100644
index 0000000..74f2c58
--- /dev/null
+++ b/Xext/tawc-dri.c
@@ -0,0 +1,127 @@
+/*
+ * SPDX-License-Identifier: MIT
+ *
+ * TAWC-DRI X11 extension: Phase 1 stub.
+ *
+ * Registers the extension, replies to QueryVersion, accepts and acks
+ * PresentBuffer with the buffer-id field treated as opaque.
+ *
+ * Phase 2 will route PresentBuffer's buffer-id (a real AHB handle
+ * shipped from a chroot client) into xwayland-tawc.c. See
+ * notes/xwayland.md.
+ */
+
+#ifdef HAVE_DIX_CONFIG_H
+#include <dix-config.h>
+#endif
+
+#include <X11/X.h>
+#include <X11/Xproto.h>
+
+#include "misc.h"
+#include "os.h"
+#include "dixstruct.h"
+#include "extnsionst.h"
+#include "extinit.h"
+
+#include "Xext/tawcdriproto.h"
+
+static int
+ProcTAWCDRIQueryVersion(ClientPtr client)
+{
+    REQUEST(xTAWCDRIQueryVersionReq);
+    xTAWCDRIQueryVersionReply rep;
+
+    REQUEST_SIZE_MATCH(xTAWCDRIQueryVersionReq);
+
+    rep = (xTAWCDRIQueryVersionReply) {
+        .type = X_Reply,
+        .sequenceNumber = client->sequence,
+        .length = 0,
+        .majorVersion = TAWCDRI_MAJOR,
+        .minorVersion = TAWCDRI_MINOR,
+    };
+    if (client->swapped) {
+        swaps(&rep.sequenceNumber);
+        swapl(&rep.length);
+        swapl(&rep.majorVersion);
+        swapl(&rep.minorVersion);
+    }
+    WriteToClient(client, sizeof(rep), &rep);
+    return Success;
+}
+
+static int
+ProcTAWCDRIPresentBuffer(ClientPtr client)
+{
+    REQUEST(xTAWCDRIPresentBufferReq);
+    REQUEST_SIZE_MATCH(xTAWCDRIPresentBufferReq);
+    /* Phase 1 stub: drop on the floor. Phase 2 routes through
+     * xwayland-tawc.c. */
+    return Success;
+}
+
+static int
+ProcTAWCDRIDispatch(ClientPtr client)
+{
+    REQUEST(xReq);
+    switch (stuff->data) {
+    case X_TAWCDRIQueryVersion:
+        return ProcTAWCDRIQueryVersion(client);
+    case X_TAWCDRIPresentBuffer:
+        return ProcTAWCDRIPresentBuffer(client);
+    default:
+        return BadRequest;
+    }
+}
+
+static int _X_COLD
+SProcTAWCDRIQueryVersion(ClientPtr client)
+{
+    REQUEST(xTAWCDRIQueryVersionReq);
+    swaps(&stuff->length);
+    REQUEST_SIZE_MATCH(xTAWCDRIQueryVersionReq);
+    swapl(&stuff->majorVersion);
+    swapl(&stuff->minorVersion);
+    return ProcTAWCDRIQueryVersion(client);
+}
+
+static int _X_COLD
+SProcTAWCDRIPresentBuffer(ClientPtr client)
+{
+    REQUEST(xTAWCDRIPresentBufferReq);
+    swaps(&stuff->length);
+    REQUEST_SIZE_MATCH(xTAWCDRIPresentBufferReq);
+    swapl(&stuff->window);
+    swapl(&stuff->bufferId);
+    swaps(&stuff->width);
+    swaps(&stuff->height);
+    swapl(&stuff->format);
+    return ProcTAWCDRIPresentBuffer(client);
+}
+
+static int _X_COLD
+SProcTAWCDRIDispatch(ClientPtr client)
+{
+    REQUEST(xReq);
+    switch (stuff->data) {
+    case X_TAWCDRIQueryVersion:
+        return SProcTAWCDRIQueryVersion(client);
+    case X_TAWCDRIPresentBuffer:
+        return SProcTAWCDRIPresentBuffer(client);
+    default:
+        return BadRequest;
+    }
+}
+
+void
+tawc_dri_extension_init(void)
+{
+    AddExtension(TAWCDRI_NAME,
+                 TAWCDRINumberEvents,
+                 TAWCDRINumberErrors,
+                 ProcTAWCDRIDispatch,
+                 SProcTAWCDRIDispatch,
+                 NULL,
+                 StandardMinorOpcode);
+}
diff --git a/Xext/tawcdriproto.h b/Xext/tawcdriproto.h
new file mode 100644
index 0000000..7acdc75
--- /dev/null
+++ b/Xext/tawcdriproto.h
@@ -0,0 +1,62 @@
+/*
+ * SPDX-License-Identifier: MIT
+ *
+ * TAWC-DRI: AHB-shipping X11 protocol extension. AHB equivalent of
+ * DRI3. Phase 1 wires only the extension's existence and a no-op
+ * PresentBuffer; Phase 2 plugs AHB allocation behind it. See
+ * notes/xwayland.md.
+ */
+
+#ifndef _TAWCDRIPROTO_H_
+#define _TAWCDRIPROTO_H_
+
+#include <X11/X.h>
+#include <X11/Xmd.h>
+#include <X11/Xproto.h>
+
+#define TAWCDRI_NAME "TAWC-DRI"
+#define TAWCDRI_MAJOR 0
+#define TAWCDRI_MINOR 1
+
+#define X_TAWCDRIQueryVersion  0
+#define X_TAWCDRIPresentBuffer 1
+
+#define TAWCDRINumberErrors 0
+#define TAWCDRINumberEvents 0
+
+typedef struct {
+    CARD8  reqType;
+    CARD8  tawcReqType;
+    CARD16 length B16;
+    CARD32 majorVersion B32;
+    CARD32 minorVersion B32;
+} xTAWCDRIQueryVersionReq;
+#define sz_xTAWCDRIQueryVersionReq 12
+
+typedef struct {
+    BYTE   type;
+    BYTE   pad1;
+    CARD16 sequenceNumber B16;
+    CARD32 length B32;
+    CARD32 majorVersion B32;
+    CARD32 minorVersion B32;
+    CARD32 pad2;
+    CARD32 pad3;
+    CARD32 pad4;
+    CARD32 pad5;
+} xTAWCDRIQueryVersionReply;
+#define sz_xTAWCDRIQueryVersionReply 32
+
+typedef struct {
+    CARD8  reqType;
+    CARD8  tawcReqType;
+    CARD16 length B16;
+    CARD32 window B32;
+    CARD32 bufferId B32;
+    CARD16 width B16;
+    CARD16 height B16;
+    CARD32 format B32;
+} xTAWCDRIPresentBufferReq;
+#define sz_xTAWCDRIPresentBufferReq 20
+
+#endif /* _TAWCDRIPROTO_H_ */
