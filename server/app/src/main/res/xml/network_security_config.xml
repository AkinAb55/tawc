<?xml version="1.0" encoding="utf-8"?>
<!-- Allow plaintext HTTP for the Arch Linux ARM mirror. The bootstrap
     tarball URL (http://os.archlinuxarm.org/...) does not have an HTTPS
     equivalent. Everything else stays HTTPS-only. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">archlinuxarm.org</domain>
    </domain-config>
</network-security-config>
