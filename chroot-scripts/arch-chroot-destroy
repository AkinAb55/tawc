#!/data/data/com.termux/files/usr/bin/bash
# Unmount and delete the Arch Linux ARM chroot.
# Run from Termux. Requires root (su).
# Usage: ./arch-chroot-destroy

set -euo pipefail

CHROOT_DIR="/data/local/arch-chroot"

if ! su -c "[ -d '$CHROOT_DIR' ]"; then
    echo "Nothing to clean up -- $CHROOT_DIR does not exist."
    exit 0
fi

echo "This will permanently delete the chroot at $CHROOT_DIR"
read -p "Are you sure? [y/N] " confirm
if [[ "$confirm" != [yY] ]]; then
    echo "Aborted."
    exit 1
fi

echo "==> Unmounting bind mounts..."
for mnt in dev/pts dev proc sys vendor system; do
    su -c "mountpoint -q '$CHROOT_DIR/$mnt' 2>/dev/null && umount '$CHROOT_DIR/$mnt' || true"
done

echo "==> Removing $CHROOT_DIR..."
su -c "rm -rf '$CHROOT_DIR'"

echo "==> Done. Chroot removed."
