#!/bin/bash
# Run the cleat-driven tawcroot test runner.
#
# A single binary at `build/tawcroot-host/tests` runs four layers of
# tests (per `notes/tawcroot.md` "Testing strategy"):
#
#   - tawcroot/tests/unit/         pure-function unit tests (cleat-direct)
#   - tawcroot/tests/handler/      handler/filter tests (fork tawcroot-testhost)
#   - tawcroot/tests/integration/  full-supervisor tests (fork production tawcroot)
#   - tawcroot/tests/diff/         (future) differential tests vs proot
#
# All four are registered through cleat and share one filter syntax,
# one exit code, one report. Positional args are full-match regexes
# against `module`, `name`, or `module::name` (e.g. `handler/test_phase0`,
# `phase1_path_translation_smoke`, `.*phase.*`). Multiple args are
# combined with OR. See cleat docs/test_framework.md.
#
# Modes:
#   - host (default) — runs the cleat binary directly on the dev box.
#   - device         — pushes `tawcroot-testhost` to the selected Android
#                target via adb and exec's the in-binary smokes via su.
#                Required for Android-shape coverage. Selection within
#                device mode follows the rest of the tawc tree: `.tawctarget`
#                / `TAWC_TARGET=device|emulator` (sourced from
#                `client/select-device.sh` — the only tawc-app coupling
#                in this script). Currently runs the phase-0/phase-1
#                testhost flows as adb shell commands — NOT the cleat
#                orchestrator (which is host-only). Future work could
#                cross-link cleat for android.
#
# Usage:
#   bash tawcroot/test                # everything, host
#   bash tawcroot/test --device       # everything, device
#   bash tawcroot/test phase0         # filter (host)
#   bash tawcroot/test --no-build     # reuse existing build/
#   bash tawcroot/test --list         # list cleat tests (host)

set -euo pipefail

TAWCROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$TAWCROOT_DIR/.." && pwd)"

BUILD=1
MODE=host
PASSTHROUGH=()
for arg in "$@"; do
    case "$arg" in
        --no-build) BUILD=0 ;;
        --host)     MODE=host ;;
        --device)   MODE=device ;;
        *)          PASSTHROUGH+=("$arg") ;;
    esac
done

# `TAWC_TARGET=device|emulator` flips device mode on without `--device`,
# matching the convention other tawc scripts use.
case "${TAWC_TARGET:-}" in
    device|emulator)    MODE=device ;;
esac

# ---- host mode -----------------------------------------------------------
if [ "$MODE" = "host" ]; then
    if [ "$BUILD" = "1" ]; then
        bash "$TAWCROOT_DIR/build" --abi=host
    fi
    BIN="$REPO_DIR/build/tawcroot-host/tests"
    [ -x "$BIN" ] || { echo "ERROR: $BIN missing — drop --no-build?" >&2; exit 1; }
    exec "$BIN" "${PASSTHROUGH[@]}"
fi

# ---- device mode ---------------------------------------------------------
# Cleat is host-only (links glibc dynamically); we can't run the cleat
# orchestrator on Android today. Instead exec the testhost binary
# directly via adb and grep for PASS lines, the same way the script did
# before the cleat refactor. Keeps Android-shape coverage alive without
# duplicating the test list.
# shellcheck disable=SC1091
source "$REPO_DIR/client/select-device.sh"   # sets ANDROID_SERIAL (tawc-app glue)

DEVICE_ABI=$(adb shell getprop ro.product.cpu.abi | tr -d '\r\n')
case "$DEVICE_ABI" in
    arm64-v8a)  BUILD_ABI=aarch64 ;;
    x86_64)     BUILD_ABI=x86_64 ;;
    *) echo "ERROR: unsupported device ABI: '$DEVICE_ABI'" >&2; exit 1 ;;
esac

if [ "$BUILD" = "1" ]; then
    bash "$TAWCROOT_DIR/build" "--abi=$BUILD_ABI" --testhost
    bash "$TAWCROOT_DIR/build-fixtures" "$BUILD_ABI"
fi

LOCAL_BIN="$REPO_DIR/build/tawcroot-$BUILD_ABI/libtawcroot-testhost.so"
LOCAL_PROD="$REPO_DIR/build/tawcroot-$BUILD_ABI/libtawcroot.so"
LOCAL_FIXTURES_DIR="$REPO_DIR/build/tawcroot-$BUILD_ABI/programs"
[ -f "$LOCAL_BIN" ] || { echo "ERROR: $LOCAL_BIN missing — drop --no-build?" >&2; exit 1; }
[ -f "$LOCAL_PROD" ] || { echo "ERROR: $LOCAL_PROD missing — drop --no-build?" >&2; exit 1; }

SCRATCH=/data/local/claude-debug
ROOTFS=$SCRATCH/fake-rootfs
TR=$SCRATCH/tawcroot-testhost
PROD=$SCRATCH/tawcroot
FIXTURES=$SCRATCH/programs

adb push "$LOCAL_BIN" /data/local/tmp/tawcroot-testhost > /dev/null
adb shell "su -c 'cp /data/local/tmp/tawcroot-testhost $TR && chmod +x $TR'"
adb push "$LOCAL_PROD" /data/local/tmp/tawcroot > /dev/null
adb shell "su -c 'cp /data/local/tmp/tawcroot $PROD && chmod +x $PROD'"
adb shell "su -c 'mkdir -p $FIXTURES'"
for f in "$LOCAL_FIXTURES_DIR"/*; do
    [ -f "$f" ] || continue
    name=$(basename "$f")
    adb push "$f" /data/local/tmp/"$name" > /dev/null
    adb shell "su -c 'cp /data/local/tmp/$name $FIXTURES/$name && chmod +x $FIXTURES/$name'"
done

adb shell "su -c '
set -e
rm -rf $ROOTFS
mkdir -p $ROOTFS/etc $ROOTFS/usr/lib $ROOTFS/run
echo hello-from-rootfs > $ROOTFS/etc/probe
ln -s usr/lib $ROOTFS/lib
echo libprobe-data > $ROOTFS/usr/lib/probe.so
ln -sf /etc/passwd $ROOTFS/etc/host-secret
ln -sf /etc/probe  $ROOTFS/altpath
ln -sf chain2      $ROOTFS/chain1
ln -sf chain3      $ROOTFS/chain2
ln -sf etc/probe   $ROOTFS/chain3
ln -sf loop        $ROOTFS/loop
'"

run_device() {
    local label="$1"; shift
    echo "=== $label ==="
    local out rc=0
    out=$(adb shell "su -c '$*' 2>&1") || rc=$?
    echo "$out"
    if [ "$rc" != "0" ]; then
        echo "FAIL: '$label' exited $rc" >&2
        return 1
    fi
    if echo "$out" | grep -q "FAIL"; then
        echo "FAIL: '$label' contained a FAIL line" >&2
        return 1
    fi
    if ! echo "$out" | tail -1 | grep -qE "(PHASE-1 SMOKE: PASS|CHILD SMOKE: PASS)"; then
        echo "FAIL: '$label' did not end on a PASS line" >&2
        return 1
    fi
}

run_device "phase-0 (foundation + --exec-child)"               "$TR"
run_device "phase-1 + phase-0.5 (path + runtime invariants)"   "$TR -r $ROOTFS"

# ---- loader smoke (phase 2): production tawcroot --exec <fixture> ----
#
# Runs each fixture under the production tawcroot binary and asserts
# the exit code. Skips fixtures that aren't present for this ABI
# (tawcroot/build-fixtures emits them when sources exist). Loader-
# driver self-failure is in [60..79]; collisions with fixture exit
# codes are documented inline.
loader_smoke() {
    local label="$1" expected="$2"; shift 2
    local cmd="$*"
    local actual rc=0
    actual=$(adb shell "su -c 'cd $SCRATCH && $cmd; echo __exit=\$?' 2>&1") || rc=$?
    local got
    got=$(echo "$actual" | grep -oE '__exit=[0-9-]+' | tail -1 | cut -d= -f2)
    if [ "$rc" != "0" ] || [ -z "$got" ]; then
        echo "FAIL: $label (adb shell rc=$rc, raw=$actual)" >&2
        return 1
    fi
    if [ "$got" != "$expected" ]; then
        echo "FAIL: $label (expected $expected, got $got)" >&2
        echo "  output: $actual" >&2
        return 1
    fi
    echo "  [ok ] $label (exit $got)"
}

echo "=== loader smoke (phase 2) ==="
if adb shell "su -c '[ -x $FIXTURES/static_exit42 ]'" >/dev/null 2>&1; then
    loader_smoke "static_exit42 → 42" 42 "$PROD --exec $FIXTURES/static_exit42"
fi
if adb shell "su -c '[ -x $FIXTURES/static_argc_random ]'" >/dev/null 2>&1; then
    # det_random[0] = 0x55 → exit (0x55 & 0x7f) + 100 = 185, but the
    # device test passes via real getrandom from the loader's perspective
    # (driver fills random16 from the kernel) — we can't predict the
    # byte. Instead pass argv that forces a *failure* path we CAN
    # predict: argc=2 → exit 99 (bin runs successfully). For full
    # success-path coverage we'd need the test driver to also pass a
    # known random16, which is what the host unit test does.
    loader_smoke "static_argc_random argc-fail → 99" 99 \
        "$PROD --exec $FIXTURES/static_argc_random just-one-arg"
    # On success path, exit code is in [100, 227]; just check it ran
    # cleanly (no signal, no driver-failure) by passing the right shape
    # and accepting any code in 100..227 OR the documented sub-failures.
    actual=$(adb shell "su -c 'cd $SCRATCH && X=1 $PROD --exec $FIXTURES/static_argc_random alpha beta; echo __exit=\$?'" 2>&1)
    got=$(echo "$actual" | grep -oE '__exit=[0-9-]+' | tail -1 | cut -d= -f2)
    if [ -z "$got" ] || [ "$got" -lt 100 ] || [ "$got" -gt 227 ]; then
        echo "FAIL: static_argc_random success path (expected 100..227, got $got)" >&2
        echo "  output: $actual" >&2
        exit 1
    fi
    echo "  [ok ] static_argc_random success → exit $got (random byte)"
fi
if adb shell "su -c '[ -x $FIXTURES/dynamic_exit42 ]'" >/dev/null 2>&1; then
    loader_smoke "dynamic_exit42 → 42 (via /system/bin/linker64)" 42 \
        "$PROD --exec $FIXTURES/dynamic_exit42"
fi
if adb shell "su -c '[ -x $FIXTURES/dynamic_argv_check ]'" >/dev/null 2>&1; then
    loader_smoke "dynamic_argv_check → 42" 42 \
        "TAWC_TEST=ok $PROD --exec $FIXTURES/dynamic_argv_check alpha beta"
fi

echo "=== ALL SMOKE PASSED ($BUILD_ABI on $ANDROID_SERIAL) ==="
