#!/bin/bash
# Build the memfd SELinux relabeling shim inside the chroot.
# Run from the host. Pushes source, builds in chroot.
#
# Usage: bash client/memfd-selinux-shim/build
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
CHROOT="/data/local/arch-chroot"
BUILD_DIR="/tmp/memfd-selinux-shim"

echo "==> Pushing source..."
adb push "$SCRIPT_DIR/memfd-selinux-shim.c" /data/local/tmp/
adb push "$REPO_DIR/client/arch-chroot-run" /data/local/tmp/

# Copy source into chroot (needs root for /data/local/arch-chroot/).
adb shell "su -c 'mkdir -p $CHROOT$BUILD_DIR && cp /data/local/tmp/memfd-selinux-shim.c $CHROOT$BUILD_DIR/'"

# Build inside chroot. arch-chroot-run handles su internally.
echo "==> Building in chroot..."
adb shell "/system_ext/bin/bash /data/local/tmp/arch-chroot-run 'cd $BUILD_DIR && gcc -shared -fPIC -o libmemfd-selinux-shim.so memfd-selinux-shim.c -Wall -g && echo Build successful && ls -la libmemfd-selinux-shim.so'"

echo "==> Done"
echo "Usage: LD_PRELOAD=$BUILD_DIR/libmemfd-selinux-shim.so <wayland-client>"
