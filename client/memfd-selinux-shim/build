#!/bin/bash
# Build the memfd SELinux relabeling shim inside the chroot.
set -e

CHROOT="/data/local/arch-chroot"
BUILD="/tmp/memfd-selinux-shim"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "=== Pushing source ==="
TMP="/data/local/tmp/tawc-build"
adb shell "mkdir -p $TMP"
adb push "$SCRIPT_DIR/memfd-selinux-shim.c" "$TMP/"
adb shell "su -c 'mkdir -p $CHROOT$BUILD && cp $TMP/memfd-selinux-shim.c $CHROOT$BUILD/'"

echo "=== Building ==="
adb shell "su -c 'chroot $CHROOT /bin/bash -c \"
export PATH=/usr/local/bin:/usr/bin:/bin
cd $BUILD

gcc -shared -fPIC -o libmemfd-selinux-shim.so \
    memfd-selinux-shim.c \
    -Wall -g

echo Build successful
ls -la libmemfd-selinux-shim.so
\"'"

echo "=== Done ==="
echo "Usage: LD_PRELOAD=$BUILD/libmemfd-selinux-shim.so <wayland-client>"
