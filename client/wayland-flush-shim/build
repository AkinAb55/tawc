#!/bin/bash
# Build the Wayland flush shim inside the chroot.
set -e

CHROOT="/data/local/arch-chroot"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "=== Pushing source ==="
TMP="/data/local/tmp/tawc-build"
adb shell "mkdir -p $TMP"
adb push "$SCRIPT_DIR/flush-shim.c" "$TMP/"
adb shell "su -c 'cp $TMP/flush-shim.c $CHROOT/tmp/'"

echo "=== Building ==="
adb shell "su -c 'chroot $CHROOT /bin/bash -c \"
export PATH=/usr/local/bin:/usr/bin:/bin
cd /tmp
gcc -shared -fPIC -o libwayland-flush-shim.so flush-shim.c -ldl -lwayland-client -lpthread -Wall
echo Build successful
ls -la libwayland-flush-shim.so
\"'"

echo "=== Done ==="
echo "To use: LD_PRELOAD=/tmp/libwayland-flush-shim.so <app>"
