#!/system/bin/sh
# Unmount and delete the Arch Linux ARM chroot.
# Run from Termux. Requires root (su).
# Usage: ./arch-chroot-destroy

set -euo pipefail

CHROOT_DIR="/data/local/arch-chroot"

if ! su -c "[ -d '$CHROOT_DIR' ]"; then
    echo "Nothing to clean up -- $CHROOT_DIR does not exist."
    exit 0
fi

echo "This will permanently delete the chroot at $CHROOT_DIR"
printf "Are you sure? [y/N] "
read confirm
case "$confirm" in
    [yY]) ;;
    *) echo "Aborted."; exit 1 ;;
esac

# Unmount ALL mount points under the chroot (in reverse order to handle nesting).
# This is critical -- if bind mounts are still active, rm -rf will delete real
# system files (like /dev nodes) and can crash the device.
echo "==> Unmounting all mounts under $CHROOT_DIR..."
su -c "cat /proc/mounts" | grep "$CHROOT_DIR" | awk '{print $2}' | sort -r | while read -r mnt; do
    echo "    umount $mnt"
    su -c "umount '$mnt'" || su -c "umount -l '$mnt'" || true
done || true

# Verify nothing is still mounted
remaining=$(su -c "cat /proc/mounts" | grep -c "$CHROOT_DIR" || true)
if [ "$remaining" -gt 0 ]; then
    echo "ERROR: $remaining mount(s) still active under $CHROOT_DIR:"
    su -c "cat /proc/mounts" | grep "$CHROOT_DIR" || true
    echo "Refusing to rm -rf with active mounts. Unmount manually first."
    exit 1
fi

echo "==> Removing $CHROOT_DIR..."
su -c "rm -rf '$CHROOT_DIR'"

echo "==> Done. Chroot removed."
