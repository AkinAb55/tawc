#!/bin/bash
# Enter the in-app Arch chroot via adb. Replaces client/arch-chroot-run
# (which targeted the legacy /data/local/arch-chroot/ tree).
#
# All the mount + chroot logic lives in <installation-dir>/enter.sh,
# auto-generated by the app's ChrootMounter on every install / chroot
# entry. This script just shells out to `adb shell su -c '<enter.sh>'`
# with a base64-encoded command, so there's only one source of truth
# for the mount snippet (the Kotlin generator in ChrootMounter.kt).
#
# Requires:
#   - the `me.phie.tawc` app installed
#   - an installation present at /data/data/me.phie.tawc/distros/<id>/
#     (install via `am start -n me.phie.tawc/.install.InstallActivity
#     --es autoStart true --es id arch`, or the home-screen Install button)
#   - root via Magisk `su` granted to adb shell (uid 2000)
#
# Usage:
#   client/tawc-chroot-run                       # interactive shell
#   client/tawc-chroot-run "<command>"           # run a command and exit
#   TAWC_INSTALL_ID=<id> client/tawc-chroot-run  # non-default installation
set -euo pipefail

INSTALL_ID="${TAWC_INSTALL_ID:-arch}"
INSTALL_DIR="/data/data/me.phie.tawc/distros/$INSTALL_ID"
ENTER="$INSTALL_DIR/enter.sh"

# Quick existence check via su (the app data dir is 0700, adb shell
# without su can't even stat it).
if ! adb shell "su -c 'test -x \"$ENTER\"'" >/dev/null 2>&1; then
    cat >&2 <<EOF
ERROR: $ENTER not found or not executable on the device.

Did you install the chroot? From the host:
  adb shell am start -n me.phie.tawc/.install.InstallActivity \\
      --es autoStart true --es id $INSTALL_ID

Tail progress:
  adb logcat -s tawc-install
EOF
    exit 1
fi

if [ $# -gt 0 ]; then
    # The chroot command may contain anything; b64-encode so we don't
    # have to quote it through host-shell -> adb shell -> su -c -> bash.
    cmd_b64=$(printf '%s' "$*" | base64 | tr -d '\n')
    # `adb shell` returns the remote exit code on Android 8+; -t isn't
    # needed because we don't want a tty for non-interactive runs (it
    # mangles \r\n into output and confuses callers).
    exec adb shell "su -c '$ENTER $cmd_b64'"
else
    # Interactive: -t for a real tty, no b64 payload.
    exec adb shell -t "su -c '$ENTER'"
fi
