#!/bin/bash
# Build the test Wayland client inside the chroot.
set -e

CHROOT="/data/local/arch-chroot"
# Build dir inside chroot (visible from both host and chroot paths)
BUILD_DIR_HOST="$CHROOT/tmp/tawc-client"
BUILD_DIR_CHROOT="/tmp/tawc-client"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "=== Pushing source files ==="
TMP="/data/local/tmp/tawc-build"
adb shell "mkdir -p $TMP"
adb push "$SCRIPT_DIR/test-wayland-client.c" "$TMP/"
adb push "$SCRIPT_DIR/../server/compositor/protocols/tawc_buffer_v1.xml" "$TMP/"
adb shell "su -c 'mkdir -p $BUILD_DIR_HOST && cp $TMP/* $BUILD_DIR_HOST/'"

echo "=== Generating protocol code in chroot ==="
adb shell "su -c 'chroot $CHROOT /bin/bash -c \"
export PATH=/usr/local/bin:/usr/bin:/bin
cd $BUILD_DIR_CHROOT

# Generate xdg-shell client code
XDG_SHELL=/usr/share/wayland-protocols/stable/xdg-shell/xdg-shell.xml
wayland-scanner client-header \\\$XDG_SHELL xdg-shell-client.h
wayland-scanner private-code \\\$XDG_SHELL xdg-shell-client.c

# Generate tawc_buffer_v1 client code
wayland-scanner client-header tawc_buffer_v1.xml tawc-buffer-v1-client.h
wayland-scanner private-code tawc_buffer_v1.xml tawc-buffer-v1-client.c

echo Protocol code generated
ls -la *.h *.c
\"'"

echo "=== Building test client ==="
adb shell "su -c 'chroot $CHROOT /bin/bash -c \"
export PATH=/usr/local/bin:/usr/bin:/bin
cd $BUILD_DIR_CHROOT
gcc -o test-wayland-client \
    test-wayland-client.c \
    xdg-shell-client.c \
    tawc-buffer-v1-client.c \
    -lwayland-client \
    -ldl \
    -z execstack \
    -I. \
    -Wall -g
echo Build successful
ls -la test-wayland-client
\"'"

echo "=== Done ==="
echo "To run:"
echo "  adb shell su -c 'chroot $CHROOT /bin/bash -c \"WAYLAND_DISPLAY=/tmp/tawc-wayland $BUILD_DIR_CHROOT/test-wayland-client\"'"
