#!/bin/bash
# Build our libhybris fork inside the Android chroot.
# Syncs local ./libhybris + shim sources to the phone and builds inside the chroot.
#
# Usage: bash client/build-libhybris [--clean] [--if-needed]
#   --clean:     full reconfigure from scratch
#   --if-needed: skip if source hash matches stamp on phone

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIBHYBRIS_DIR="$REPO_DIR/libhybris"
# In-app rootfs (see notes/installation.md). Owned by the app uid; root
# is needed to write into it from adb shell, which is fine because the
# build commands all run via tawc-chroot-run (su).
CHROOT="/data/data/me.phie.tawc/installations/arch/rootfs"

# shellcheck source=select-device.sh
source "$SCRIPT_DIR/select-device.sh"

# libhybris needs real Android GPU drivers, which emulators don't have.
case "${ANDROID_SERIAL:-}" in
    emulator-*)
        echo "ERROR: build-libhybris doesn't make sense against an emulator" >&2
        echo "       (no Android GPU drivers / vendor blobs to bind to)." >&2
        echo "       Set TAWC_TARGET=device or ANDROID_SERIAL=<real device>." >&2
        exit 1
        ;;
esac
STAMP="$CHROOT/usr/local/lib/.libhybris-build-stamp"
INSTALLED_LIB="$CHROOT/usr/local/lib/libhybris-common.so.1.0.0"

if [ ! -d "$LIBHYBRIS_DIR/hybris" ]; then
    echo "ERROR: $LIBHYBRIS_DIR/hybris not found."
    echo "Clone: git clone https://github.com/wmww/libhybris.git ./libhybris"
    exit 1
fi

CLEAN=0; IF_NEEDED=0
for arg in "$@"; do
    case "$arg" in
        --clean) CLEAN=1 ;;
        --if-needed) IF_NEEDED=1 ;;
        *) echo "ERROR: unknown arg: $arg"; exit 1 ;;
    esac
done

# Hash all build inputs so --if-needed can detect changes.
SOURCE_HASH=$(
    cd "$REPO_DIR"
    {
        find libhybris -type f ! -path '*/.git/*' ! -path '*/autom4te.cache/*' \
            -print0 | LC_ALL=C sort -z | xargs -0 sha256sum
        sha256sum client/libgl-shim.c client/libglesv2-shim.c \
                  client/build-libhybris client/build-libhybris-chroot.sh
        [ -f client/fix-android-headers ] && sha256sum client/fix-android-headers || true
    } | sha256sum | awk '{print $1}'
)

# --if-needed: skip if hash matches and the lib is installed
if [ "$IF_NEEDED" = "1" ] && [ "$CLEAN" = "0" ]; then
    STORED=$(adb shell "su -c '[ -f $INSTALLED_LIB ] && cat $STAMP 2>/dev/null'" 2>/dev/null \
             | tr -d '\r' || true)
    if [ "$STORED" = "$SOURCE_HASH" ]; then
        echo "==> libhybris up-to-date ($SOURCE_HASH), skipping"
        exit 0
    fi
    echo "==> libhybris changed or not installed, rebuilding"
fi

# Bundle libhybris source + shim sources + build helpers into one tarball.
echo "==> Packing sources..."
TAR=$(mktemp /tmp/libhybris-bundle.XXXXXX.tar.gz)
trap 'rm -f "$TAR"' EXIT

EXTRA_FILES="libgl-shim.c libglesv2-shim.c build-libhybris-chroot.sh"
[ -f "$SCRIPT_DIR/fix-android-headers" ] && EXTRA_FILES="$EXTRA_FILES fix-android-headers"

tar czf "$TAR" \
    -C "$REPO_DIR" --exclude='.git' --exclude='autom4te.cache' libhybris/ \
    -C "$SCRIPT_DIR" $EXTRA_FILES

# Push bundle to the phone (in-app rootfs is root-owned, so we stage in
# /data/local/tmp and copy across via su).
echo "==> Pushing to phone..."
adb push "$TAR" /data/local/tmp/libhybris-bundle.tar.gz
adb shell "su -c 'cp /data/local/tmp/libhybris-bundle.tar.gz $CHROOT/tmp/'"

# Build inside chroot via tawc-chroot-run (mount + chroot wrapper auto-
# generated by ChrootMounter; see notes/installation.md).
echo "==> Building inside chroot..."
STAMP_CHROOT="/usr/local/lib/.libhybris-build-stamp"
"$SCRIPT_DIR/tawc-chroot-run" \
    "tar xzf /tmp/libhybris-bundle.tar.gz -C /tmp && rm /tmp/libhybris-bundle.tar.gz && bash /tmp/build-libhybris-chroot.sh $CLEAN && echo $SOURCE_HASH > $STAMP_CHROOT"
echo "==> libhybris build complete ($SOURCE_HASH)"
