#!/bin/bash
# Create an Arch Linux x86_64 chroot inside a rooted Android emulator.
# Run from the host (drives over adb). Counterpart of arch-chroot-create,
# which runs from Termux on a real device.
#
# Prereqs (see notes/emulator.md):
#   - emulator-* device connected
#   - rootAVD-installed Magisk on the emulator, with adb shell uid 2000
#     pre-granted root via the policies table (see notes)
#
# Safe to re-run -- skips steps already done.
# Usage: bash client/arch-chroot-create-emulator [--clean]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TAWC_TARGET=emulator
export TAWC_TARGET
# shellcheck source=select-device.sh
source "$SCRIPT_DIR/select-device.sh"

case "$ANDROID_SERIAL" in
    emulator-*) ;;
    *)
        echo "ERROR: arch-chroot-create-emulator only runs against emulators." >&2
        echo "       Use arch-chroot-create from Termux for real devices." >&2
        exit 1 ;;
esac

CLEAN=0
for arg in "$@"; do
    case "$arg" in
        --clean) CLEAN=1 ;;
        *) echo "ERROR: unknown arg: $arg"; exit 1 ;;
    esac
done

CHROOT_DIR="/data/local/arch-chroot"
TARBALL_URL="https://geo.mirror.pkgbuild.com/iso/latest/archlinux-bootstrap-x86_64.tar.zst"
HOST_CACHE="/tmp/tawc-arch-bootstrap.tar.zst"
DEVICE_TAR="/data/local/tmp/arch-bootstrap.tar"
MIRROR='Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch'

# 0. verify root via su (Magisk grant must be in place)
if ! adb shell 'su -c id' 2>/dev/null | grep -q 'uid=0'; then
    echo "ERROR: 'adb shell su -c id' did not return uid=0." >&2
    echo "       See notes/emulator.md for the rootAVD + Magisk policy steps." >&2
    exit 1
fi

# 1. clean if requested
if [ "$CLEAN" = "1" ]; then
    echo "==> --clean: tearing down existing chroot mounts and dir"
    adb shell "su -c \"
        for m in \\\$(awk '\\\$2 ~ \\\"^$CHROOT_DIR\\\" {print \\\$2}' /proc/mounts | sort -r); do
            umount \\\"\\\$m\\\" 2>/dev/null || umount -l \\\"\\\$m\\\" 2>/dev/null || true
        done
        rm -rf $CHROOT_DIR
    \""
fi

# 2. download tarball on host if missing
if [ ! -f "$HOST_CACHE" ]; then
    echo "==> downloading Arch x86_64 bootstrap tarball (~120MB)"
    curl -L -o "$HOST_CACHE" "$TARBALL_URL"
fi

# 3. extract on device (skip if /usr already exists)
if adb shell "su -c '[ -d $CHROOT_DIR/usr ]'" 2>/dev/null; then
    echo "==> chroot already extracted, skipping extract"
else
    echo "==> decompressing tarball on host (~550MB tar)"
    TMP_TAR=$(mktemp /tmp/tawc-bootstrap.XXXXXX.tar)
    trap 'rm -f "$TMP_TAR"' EXIT
    zstd -d -c "$HOST_CACHE" > "$TMP_TAR"

    echo "==> pushing tar to emulator"
    adb push "$TMP_TAR" "$DEVICE_TAR" >/dev/null
    rm -f "$TMP_TAR"; trap - EXIT

    echo "==> extracting on emulator (toybox tar can't --strip-components hardlinks, so flatten after)"
    adb shell "su -c '
        set -e
        mkdir -p $CHROOT_DIR
        cd $CHROOT_DIR
        tar xf $DEVICE_TAR
        shopt -s dotglob 2>/dev/null || true
        for d in root.x86_64/* root.x86_64/.[!.]*; do
            [ -e \"\$d\" ] || continue
            mv \"\$d\" .
        done
        rmdir root.x86_64
        rm -f pkglist.x86_64.txt version $DEVICE_TAR
    '"
fi

# 4. mounts (minimal: dev/pts/proc/sys; no APEX/binder/vendor since
#    libhybris doesn't run on the emulator)
echo "==> setting up bind mounts"
adb shell "su -c '
    set -e
    for pair in /dev:/dev /dev/pts:/dev/pts /proc:/proc /sys:/sys; do
        src=\${pair%%:*}; dst=$CHROOT_DIR\${pair##*:}
        mkdir -p \$dst
        mountpoint -q \$dst 2>/dev/null || mount -o bind,rslave \$src \$dst
    done
'"

# 5. DNS + pacman config + mirror
echo "==> configuring DNS, pacman, mirrorlist"
adb shell "su -c '
    set -e
    echo nameserver 8.8.8.8 > $CHROOT_DIR/etc/resolv.conf
    sed -i s/^SigLevel.*/SigLevel\ =\ Never/ $CHROOT_DIR/etc/pacman.conf
    grep -q ^DisableSandbox $CHROOT_DIR/etc/pacman.conf || sed -i /^SigLevel/aDisableSandbox $CHROOT_DIR/etc/pacman.conf
    sed -i s/^CheckSpace/#CheckSpace/ $CHROOT_DIR/etc/pacman.conf
    grep -q ^IgnorePkg $CHROOT_DIR/etc/pacman.conf || sed -i \"/#CheckSpace/aIgnorePkg = linux linux-firmware linux-firmware-*\" $CHROOT_DIR/etc/pacman.conf
'"
# Mirrorlist: write via stdin so $repo/$arch survive shell quoting
echo "$MIRROR" | adb shell "su -c 'cat > $CHROOT_DIR/etc/pacman.d/mirrorlist'"

# 6. pacman init + base-devel (skip if already done)
if adb shell "su -c 'chroot $CHROOT_DIR /bin/bash -c \"command -v make\"'" >/dev/null 2>&1; then
    echo "==> base-devel already installed, skipping pacman init"
else
    echo "==> initializing pacman keyring + installing base-devel (slow)"
    adb shell "su -c 'cat > $CHROOT_DIR/tmp/setup.sh'" << 'SETUP'
#!/bin/bash
set -e
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
echo "==> pacman-key init"
pacman-key --init
pacman-key --populate archlinux
echo "==> pacman -Syu"
pacman -Syu --noconfirm
echo "==> base-devel + wayland + gtk3"
pacman -S --noconfirm --needed base-devel git libtool wayland wayland-protocols \
    pkg-config autoconf automake patchelf weston gtk3 gtk3-demos
rm -f /tmp/setup.sh
SETUP
    adb shell "su -c 'chmod 755 $CHROOT_DIR/tmp/setup.sh && chroot $CHROOT_DIR /tmp/setup.sh'"
fi

echo
echo "==> done. Chroot ready at $CHROOT_DIR on $ANDROID_SERIAL"
echo "    Run commands via: TAWC_TARGET=emulator adb shell '/system/bin/sh /data/local/tmp/arch-chroot-run <cmd>'"
echo "    (push arch-chroot-run first: adb push client/arch-chroot-run /data/local/tmp/)"
