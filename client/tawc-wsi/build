#!/bin/bash
# Build the tawc EGL wrapper (libEGL.so) and GL shims inside the chroot.
set -e

CHROOT="/data/local/arch-chroot"
BUILD="/tmp/tawc-wsi"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "=== Pushing source ==="
TMP="/data/local/tmp/tawc-build"
adb shell "mkdir -p $TMP"
adb push "$SCRIPT_DIR/tawc-egl.c" "$TMP/"
adb push "$SCRIPT_DIR/libgl-shim.c" "$TMP/"
adb push "$SCRIPT_DIR/libglesv2-shim.c" "$TMP/"
adb push "$SCRIPT_DIR/../../server/compositor/protocols/tawc_buffer_v1.xml" "$TMP/"

# Write chroot build script to avoid shell quoting issues
cat > /tmp/tawc-chroot-build.sh << 'BUILDEOF'
#!/bin/bash
set -e
export PATH=/usr/local/bin:/usr/bin:/bin
cd /tmp/tawc-wsi

# Generate tawc protocol client code
wayland-scanner client-header tawc_buffer_v1.xml tawc-buffer-v1-client.h
wayland-scanner private-code tawc_buffer_v1.xml tawc-buffer-v1-client.c

# Build EGL wrapper
gcc -shared -fPIC -o libEGL.so \
    tawc-egl.c \
    tawc-buffer-v1-client.c \
    -lwayland-client \
    -ldl \
    -lpthread \
    -I. \
    -Wall -g
ln -sf libEGL.so libEGL.so.1

# --- GL library shims ---
# Android has GLES only (no desktop GL, no GLX). We need shim libraries that
# re-export libhybris GLES symbols AND provide GLX stubs returning NULL.
# See notes/firefox.md for the full rationale.

# Copy real GLES and patch its soname to avoid circular DT_NEEDED resolution
cp /usr/local/lib/libGLESv2.so.2 libGLESv2_real.so
patchelf --set-soname libGLESv2_real.so libGLESv2_real.so

# libGLESv2.so.2 shim: GLX stubs + chains to real GLES via DT_NEEDED
gcc -shared -fPIC -o libGLESv2.so.2 libglesv2-shim.c \
    -L/tmp/tawc-wsi -l:libGLESv2_real.so \
    -Wl,-rpath,/tmp/tawc-wsi -Wl,--no-as-needed \
    -Wl,-soname,libGLESv2.so.2
ln -sf libGLESv2.so.2 libGLESv2.so

# libGL.so shim: GLX stubs + chains to real GLES via DT_NEEDED
ln -sf /usr/local/lib/libGLESv2.so.2 libGL.so.1
gcc -shared -fPIC -o libGL.so libgl-shim.c \
    -L/tmp/tawc-wsi -l:libGL.so.1 \
    -Wl,-rpath,/tmp/tawc-wsi -Wl,--no-as-needed

echo "Build successful"
ls -la libEGL.so libGL.so libGLESv2.so.2 libGLESv2_real.so
BUILDEOF

adb push /tmp/tawc-chroot-build.sh "$TMP/"
adb shell "su -c 'mkdir -p $CHROOT$BUILD && cp $TMP/* $CHROOT$BUILD/'"

echo "=== Building ==="
adb shell "su -c 'chroot $CHROOT /bin/bash $BUILD/tawc-chroot-build.sh'"

echo "=== Done ==="
echo "To use: LD_LIBRARY_PATH=$BUILD:\$LD_LIBRARY_PATH <app>"
